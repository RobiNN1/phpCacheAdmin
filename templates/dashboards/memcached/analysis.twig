{% import 'components/macros.twig' as macros %}

{% if tab_message %}
    <div class="p-4 card text-center text-gray-600 dark:text-gray-300">{{ tab_message }}</div>
{% elseif analysis is empty %}
    <div class="p-4 card text-center text-gray-600 dark:text-gray-300">There are no keys to analyze.</div>
{% else %}
    {% set summary = analysis.summary %}

    <div class="grid grid-cols-2 gap-4 mb-4 xl:grid-cols-4">
        {% for tile in analysis.tiles %}
            <div class="p-4 card">
                <h3 class="text-xs font-bold uppercase text-primary-900 dark:text-primary-400">{{ tile.label }}</h3>
                <p class="mt-1 text-xl font-semibold text-gray-900 dark:text-white">{{ tile.value }}</p>
                <p class="mt-1 text-xs text-gray-600 dark:text-gray-300">{{ tile.note }}</p>
            </div>
        {% endfor %}
    </div>

    <div class="gap-4 xl:grid xl:grid-cols-2">
        <div class="p-4 card flex flex-col h-128 mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Memory by namespace</h2>
            <p class="mb-3 text-xs text-gray-600 dark:text-gray-300">Top {{ analysis.namespaces|length }} of {{ summary.namespaces|number }} namespaces, by memory used.</p>
            <div class="overflow-auto grow">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead class="sticky top-0 z-10 bg-white dark:bg-gray-800">
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Namespace</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-20">Keys</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-24">Memory</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.namespaces %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 break-all">{{ row.name }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.count|number }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.memory|bytes }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-600 dark:text-gray-300">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="p-4 card flex flex-col h-128 mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Biggest keys</h2>
            <p class="mb-3 text-xs text-gray-600 dark:text-gray-300">The keys that use the most memory, including item overhead.</p>
            <div class="overflow-auto grow">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead class="sticky top-0 z-10 bg-white dark:bg-gray-800">
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Key</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-24">Memory</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.top_memory %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 break-all">
                                <a href="{{ link([], {view: 'key', key: row.key}) }}" class="font-semibold text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-500">{{ row.key }}</a>
                            </td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.size|bytes }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="p-4 card mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Expiration</h2>
            <p class="mb-3 text-xs text-gray-600 dark:text-gray-300">When the keys are due to expire.</p>
            <div class="overflow-x-auto">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Expires in</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-20">Keys</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.expiry %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.name }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.count|number }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-600 dark:text-gray-300">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="p-4 card mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Last used</h2>
            <p class="mb-3 text-xs text-gray-600 dark:text-gray-300">How long ago the keys were last read. Memcached evicts the least recently used keys first.</p>
            <div class="overflow-x-auto">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Last read</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-20">Keys</th>
                        <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.idle %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.name }} ago</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ row.count|number }}</td>
                            <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-600 dark:text-gray-300">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
