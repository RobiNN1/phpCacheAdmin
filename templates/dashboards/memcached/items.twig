<div class="py-4 px-6 bg-white rounded-md border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <div class="md:grid md:grid-cols-4 md:gap-4">
        {% for item, data in items %}
            {{ include('partials/panel.twig', {
                panel_title: 'Item ' ~ item,
                array: data,
            }) }}
        {% else %}
            No items.
        {% endfor %}
    </div>
</div>
