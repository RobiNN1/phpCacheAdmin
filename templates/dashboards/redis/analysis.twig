{% import 'components/macros.twig' as macros %}

{% set card = 'p-4 bg-white rounded-md border border-gray-200 dark:bg-gray-800 dark:border-gray-700' %}
{% set scroll_card = card ~ ' flex flex-col h-128' %}
{% set th = 'py-2 px-4 text-xs font-bold uppercase whitespace-nowrap' %}
{% set td = 'py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700' %}
{% set thead_sticky = 'sticky top-0 z-10 bg-white dark:bg-gray-800' %}
{% set key_link = 'font-semibold text-primary-500 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-500' %}

<div class="{{ card }} mb-4">
    <form method="get" class="flex flex-wrap gap-3 items-end">
        <input type="hidden" name="dashboard" value="redis">
        <input type="hidden" name="tab" value="analysis">
        {% if get('server') is not null %}
            <input type="hidden" name="server" value="{{ get('server') }}">
        {% endif %}
        {% if get('db') is not null %}
            <input type="hidden" name="db" value="{{ get('db') }}">
        {% endif %}

        <div class="w-full sm:w-48">
            {{ include('components/input.twig', {
                id: 'pattern',
                label: 'Match pattern',
                value: pattern,
                wrapper_class: 'flex flex-col',
            }) }}
        </div>

        <div class="w-full sm:w-36">
            {{ include('components/input.twig', {
                id: 'sample',
                label: 'Sample size',
                value: sample_size,
                type: 'number',
                wrapper_class: 'flex flex-col',
            }) }}
        </div>

        <div class="w-full sm:w-32">
            {{ include('components/input.twig', {
                id: 'depth',
                label: 'Namespace depth',
                value: depth,
                type: 'number',
                wrapper_class: 'flex flex-col',
            }) }}
        </div>

        {{ include('components/button.twig', {
            id: 'analyze',
            text: 'Run analysis',
            color: 'green',
            submit: true,
            attributes: {value: '1'},
        }) }}

        <p class="w-full text-xs text-gray-500 dark:text-gray-400">
            Scans up to the sample size with SCAN and reads each key's memory usage, type, TTL and item count.
            The database currently holds {{ total_keys|number }} keys. On a large database this is a sample, not the whole keyspace,
            so shares are relative to what was scanned.
        </p>
    </form>
</div>

{% if tab_message %}
    <div class="{{ card }} text-center text-gray-500 dark:text-gray-400">{{ tab_message }}</div>
{% elseif analysis is null %}
    <div class="{{ card }} text-center text-gray-500 dark:text-gray-400">
        Run the analysis to see where memory goes, which namespaces and types dominate, and how many keys never expire.
    </div>
{% elseif analysis is empty %}
    <div class="{{ card }} text-center text-gray-500 dark:text-gray-400">The sampled keys no longer exist.</div>
{% else %}
    {% set summary = analysis.summary %}

    <div class="grid grid-cols-2 gap-4 mb-4 {{ analysis.memory ? 'xl:grid-cols-4' : 'xl:grid-cols-3' }}">
        {% for tile in analysis.tiles %}
            <div class="{{ card }}">
                <h3 class="text-xs font-bold uppercase text-primary-900 dark:text-primary-400">{{ tile.label }}</h3>
                <p class="mt-1 text-xl font-semibold text-gray-900 dark:text-white">{{ tile.value }}</p>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">{{ tile.note }}</p>
            </div>
        {% endfor %}
    </div>

    {% if analysis.recommendations is not empty %}
        <div class="overflow-hidden mb-4 bg-white rounded-md border border-gray-200 divide-y divide-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-700">
            {% for rec in analysis.recommendations %}
                <details class="group">
                    <summary class="flex flex-wrap gap-x-3 gap-y-1 items-center py-3 px-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:bg-gray-50 dark:hover:bg-white/5">
                        <span class="text-gray-400 shrink-0 -rotate-90 transition-transform group-open:rotate-0">{{ svg('down', 10) }}</span>
                        <span class="text-sm font-semibold text-gray-900 shrink-0 dark:text-white">{{ rec.name }}</span>
                        <span class="text-xs text-gray-600 grow dark:text-gray-300">{{ rec.detail }}</span>
                        {{ macros.health_status(rec.status) }}
                    </summary>

                    <div class="px-4 pb-3 ps-9">
                        {% if rec.directive %}
                            <p class="mb-2 text-xs text-gray-400 dark:text-gray-500"><code>{{ rec.directive }}</code>
                            </p>
                        {% endif %}

                        {% if rec.keys is not empty %}
                            <ul class="mb-2 space-y-1">
                                {% for item in rec.keys %}
                                    <li class="text-xs break-all">
                                        <a href="{{ link([], {view: 'key', key: item.key}) }}" class="{{ key_link }}">{{ item.key }}</a>
                                        <span class="text-gray-500 dark:text-gray-400">{{ item.note }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}

                        <p class="text-xs text-gray-700 dark:text-gray-300">{{ rec.suggestion }}</p>
                    </div>
                </details>
            {% endfor %}
        </div>
    {% endif %}

    <div class="gap-4 xl:grid xl:grid-cols-2">
        <div class="{{ scroll_card }} mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">{{ analysis.memory ? 'Memory by namespace' : 'Keys by namespace' }}</h2>
            <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">
                Top {{ analysis.namespaces|length }} of {{ summary.namespaces|number }} namespaces,
                by {{ analysis.memory ? 'memory used in the sample' : 'the number of sampled keys' }}.
            </p>
            <div class="overflow-auto grow">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead class="{{ thead_sticky }}">
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="{{ th }}">Namespace</th>
                        <th class="{{ th }} w-20">Keys</th>
                        {% if analysis.memory %}
                            <th class="{{ th }} w-24">Memory</th>
                        {% endif %}
                        <th class="{{ th }} w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.namespaces %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="{{ td }} break-all">{{ row.name }}</td>
                            <td class="{{ td }} whitespace-nowrap">{{ row.count|number }}</td>
                            {% if analysis.memory %}
                                <td class="{{ td }} whitespace-nowrap">{{ row.memory|bytes }}</td>
                            {% endif %}
                            <td class="{{ td }}">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-500 dark:text-gray-400">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if analysis.memory %}
            <div class="{{ scroll_card }} mb-4 xl:mb-0">
                <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Biggest keys</h2>
                <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">The keys that use the most memory in the sample.</p>
                <div class="overflow-auto grow">
                    <table class="w-full text-left table-auto dark:text-gray-300">
                        <thead class="{{ thead_sticky }}">
                        <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                            <th class="{{ th }}">Key</th>
                            <th class="{{ th }} w-24">Type</th>
                            <th class="{{ th }} w-24">Memory</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in analysis.top_memory %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                                <td class="{{ td }} break-all">
                                    <a href="{{ link([], {view: 'key', key: row.key}) }}" class="{{ key_link }}">{{ row.key }}</a>
                                </td>
                                <td class="{{ td }}">{{ macros.key_type(row.type) }}</td>
                                <td class="{{ td }} whitespace-nowrap">{{ row.size|bytes }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}

        <div class="{{ analysis.memory ? card ~ ' col-span-2 xl:order-last' : scroll_card ~ ' mb-4 xl:mb-0' }}">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Keys with the most items</h2>
            <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">Collections with the highest element count. Long collections make commands that walk the whole key slow.</p>
            <div class="overflow-auto grow">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead class="{{ thead_sticky }}">
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="{{ th }}">Key</th>
                        <th class="{{ th }} w-24">Type</th>
                        <th class="{{ th }} w-24">Items</th>
                        {% if analysis.memory %}
                            <th class="{{ th }} w-24">Memory</th>
                        {% endif %}
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.top_length %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="{{ td }} break-all">
                                <a href="{{ link([], {view: 'key', key: row.key}) }}" class="{{ key_link }}">{{ row.key }}</a>
                            </td>
                            <td class="{{ td }}">{{ macros.key_type(row.type) }}</td>
                            <td class="{{ td }} whitespace-nowrap">{{ row.items|number }}</td>
                            {% if analysis.memory %}
                                <td class="{{ td }} whitespace-nowrap">{{ row.size|bytes }}</td>
                            {% endif %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="{{ td }} text-center">No collections in the sample, only strings have no item count.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="{{ card }} mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Data types</h2>
            <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">
                How the sampled keys{{ analysis.memory ? ' and their memory' : '' }} are spread across types.
            </p>
            <div class="overflow-x-auto">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="{{ th }}">Type</th>
                        <th class="{{ th }} w-20">Keys</th>
                        {% if analysis.memory %}
                            <th class="{{ th }} w-24">Memory</th>
                        {% endif %}
                        <th class="{{ th }} w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.types %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="{{ td }}">{{ macros.key_type(row.name) }}</td>
                            <td class="{{ td }} whitespace-nowrap">{{ row.count|number }}</td>
                            {% if analysis.memory %}
                                <td class="{{ td }} whitespace-nowrap">{{ row.memory|bytes }}</td>
                            {% endif %}
                            <td class="{{ td }}">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-500 dark:text-gray-400">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="{{ card }} mb-4 xl:mb-0">
            <h2 class="mb-1 text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Expiration</h2>
            <p class="mb-3 text-xs text-gray-500 dark:text-gray-400">When the sampled keys are due to expire.</p>
            <div class="overflow-x-auto">
                <table class="w-full text-left table-auto dark:text-gray-300">
                    <thead>
                    <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                        <th class="{{ th }}">TTL</th>
                        <th class="{{ th }} w-20">Keys</th>
                        <th class="{{ th }} w-40">Share</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in analysis.expiry %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                            <td class="{{ td }} whitespace-nowrap">{{ row.name }}</td>
                            <td class="{{ td }} whitespace-nowrap">{{ row.count|number }}</td>
                            <td class="{{ td }}">
                                <div class="flex gap-2 items-center">
                                    <div class="grow">{{ macros.progress(row.percent, 'lower', null, 'info') }}</div>
                                    <span class="shrink-0 text-xs text-gray-500 dark:text-gray-400">{{ row.percent }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
{% endif %}
