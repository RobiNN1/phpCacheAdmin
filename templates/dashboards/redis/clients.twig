{% import 'components/macros.twig' as macros %}

{% set th = 'py-2 px-4 text-xs font-bold uppercase whitespace-nowrap' %}
{% set td = 'py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700' %}

<div class="bg-white rounded-md border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <div class="flex flex-wrap gap-2 justify-between items-center py-4 px-6">
        <h2 class="text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Connected clients ({{ clients|length|number }})</h2>
        <p class="text-xs text-gray-500 dark:text-gray-400">Sorted by idle time. Disconnecting a client makes its next command fail; it is up to the client to reconnect.</p>
    </div>

    <div class="overflow-hidden overflow-x-auto">
        <table class="w-full text-left table-auto dark:text-gray-300">
            <thead>
            <tr class="border-t border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                <th class="{{ th }}">ID</th>
                <th class="{{ th }}">Address</th>
                {% if is_cluster %}
                    <th class="{{ th }}">Node</th>
                {% endif %}
                <th class="{{ th }} hidden md:table-cell">Name</th>
                <th class="{{ th }} hidden lg:table-cell">User</th>
                <th class="{{ th }} hidden lg:table-cell">DB</th>
                <th class="{{ th }}">Age</th>
                <th class="{{ th }}">Idle</th>
                <th class="{{ th }} hidden xl:table-cell">Memory</th>
                <th class="{{ th }} hidden md:table-cell">Last command</th>
                <th class="{{ th }} w-24"></th>
            </tr>
            </thead>
            <tbody>
            {% for client in clients %}
                <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                    <td class="{{ td }} whitespace-nowrap">{{ client.id }}</td>
                    <td class="{{ td }} whitespace-nowrap">
                        {{ client.addr }}
                        {% if client.self %}
                            {{ macros.badge('This dashboard', 'blue') }}
                        {% endif %}
                        {% for flag in client.flags %}
                            {{ macros.badge(flag, 'orange') }}
                        {% endfor %}
                    </td>
                    {% if is_cluster %}
                        <td class="{{ td }} whitespace-nowrap">{{ client.node }}</td>
                    {% endif %}
                    <td class="{{ td }} hidden md:table-cell whitespace-nowrap">{{ client.name }}</td>
                    <td class="{{ td }} hidden lg:table-cell whitespace-nowrap">{{ client.user }}</td>
                    <td class="{{ td }} hidden lg:table-cell whitespace-nowrap">{{ client.db }}</td>
                    {# Minutes are enough for how long a connection has been up, but an idle time is only
                       interesting while it is still small, so that one keeps its seconds. #}
                    <td class="{{ td }} whitespace-nowrap">{{ client.age|seconds(false) }}</td>
                    <td class="{{ td }} whitespace-nowrap">{{ client.idle|seconds }}</td>
                    <td class="{{ td }} hidden xl:table-cell whitespace-nowrap">{{ client.memory|bytes }}</td>
                    <td class="{{ td }} hidden md:table-cell whitespace-nowrap">
                        <code class="text-xs">{{ client.command }}</code></td>
                    <td class="{{ td }}">
                        {% if client.self %}
                            <span class="text-xs text-gray-400 dark:text-gray-500">&mdash;</span>
                        {% else %}
                            <form method="post" class="inline-flex">
                                <input type="hidden" name="csrf_token" value="{{ csrf }}">
                                <input type="hidden" name="kill_client" value="{{ client.id }}">
                                <button type="submit" class="inline-flex gap-1 items-center text-sm font-semibold text-red-500 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300"
                                        onclick="return confirm('Disconnect client {{ client.id }} ({{ client.addr }})?');">
                                    {{ svg('trash', 16) }} Kill
                                </button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="11" class="{{ td }} text-center">No clients.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
