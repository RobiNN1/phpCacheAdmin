<div class="bg-white rounded-md border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
    <form method="post" class="flex flex-wrap gap-3 items-end py-4 px-6 w-full md:items-center">
        <input type="hidden" name="csrf_token" value="{{ csrf }}">

        {{ include('components/input.twig', {
            id: 'slowlog_max_items',
            label: 'Display items',
            value: slowlog.max_items,
            inline_input: true,
            wrapper_class: 'flex flex-col gap-1 md:flex-row md:items-center md:gap-2',
            input_class: 'w-24',
        }) }}

        {{ include('components/input.twig', {
            id: 'slowlog_slower_than',
            label: 'Slower than (μs)',
            value: slowlog.slower_than,
            inline_input: true,
            wrapper_class: 'flex flex-col gap-1 md:flex-row md:items-center md:gap-2',
            input_class: 'w-24',
        }) }}

        {{ include('components/button.twig', {
            id: 'save',
            text: 'Save',
            color: 'green',
            submit: true,
            class: 'md:order-3',
        }) }}

        {{ include('components/button.twig', {
            id: 'resetlog',
            text: 'Reset',
            color: 'red',
            submit: true,
            class: 'md:order-5',
        }) }}

        <p class="order-last w-full text-xs text-gray-500 dark:text-gray-400 md:order-4 md:w-auto md:flex-1">This will change the config value. Default is 128 items and 10 000 μs.</p>
    </form>

    <div class="overflow-hidden overflow-x-auto">
        <table class="w-full text-left table-auto dark:text-gray-300">
            <thead>
            <tr class="border-t border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                <th class="py-2 px-6 text-xs font-bold uppercase whitespace-nowrap">ID</th>
                <th class="py-2 px-6 text-xs font-bold uppercase whitespace-nowrap">Timestamp</th>
                <th class="py-2 px-6 text-xs font-bold uppercase whitespace-nowrap">Duration</th>
                <th class="py-2 px-6 text-xs font-bold uppercase whitespace-nowrap">Command</th>
            </tr>
            </thead>
            <tbody>
            {% for item in slowlog.items %}
                <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                    <td class="py-2 px-6 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ item[0] }}</td>
                    <td class="py-2 px-6 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ item[1]|time }}</td>
                    <td class="py-2 px-6 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ item[2] }}μs</td>
                    <td class="py-2 px-6 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ item[3]|join(' ') }}</td>
                </tr>
            {% else %}
                <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                    <td colspan="4" class="py-2 px-6 text-sm text-center border-t border-gray-200 dark:text-gray-300 dark:border-gray-700">No items.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
