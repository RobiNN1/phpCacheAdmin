{% import 'components/macros.twig' as macros %}

<div class="mb-4 card">
    <div class="flex flex-wrap gap-3 justify-between items-center py-3 px-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-sm font-bold uppercase text-primary-900 dark:text-primary-400">Consumer groups</h2>
        <span class="text-xs text-gray-600 dark:text-gray-300">
            {{ stream_groups.groups|length }} group(s), {{ stream_groups.total_pending|number }} entries waiting for an acknowledgement
        </span>
    </div>

    {% if stream_groups.truncated %}
        <p class="py-2 px-4 text-xs text-gray-500 border-b border-gray-200 dark:text-gray-400 dark:border-gray-700">
            Showing the first {{ stream_groups.groups|length }} of {{ stream_groups.truncated|number }} groups.
        </p>
    {% endif %}

    <div class="overflow-hidden overflow-x-auto">
        <table class="w-full text-left table-auto dark:text-gray-300">
            <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 text-primary-900 dark:text-primary-400">
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Group</th>
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-24">Consumers</th>
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-24">Pending</th>
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap w-24">Lag</th>
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Last delivered</th>
                <th class="py-2 px-4 text-xs font-bold uppercase whitespace-nowrap">Oldest pending</th>
            </tr>
            </thead>
            <tbody>
            {% for group in stream_groups.groups %}
                <tr class="hover:bg-gray-50 dark:hover:bg-white/5">
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 font-semibold break-all">{{ group.name }}</td>
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">{{ group.consumers|number }}</td>
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">
                        {% if group.pending > 0 %}
                            {{ macros.badge(group.pending|number, 'orange') }}
                        {% else %}
                            {{ group.pending|number }}
                        {% endif %}
                    </td>
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">
                        {% if group.lag is null %}
                            <span class="text-gray-400 dark:text-gray-500" title="The server does not report the lag (Redis < 7).">&mdash;</span>
                        {% else %}
                            {{ group.lag|number }}
                        {% endif %}
                    </td>
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">
                        <code class="text-xs">{{ group.last_delivered_id }}</code></td>
                    <td class="py-2 px-4 text-sm border-t border-gray-200 dark:text-gray-300 dark:border-gray-700 whitespace-nowrap">
                        {% if group.oldest_pending %}
                            <code class="text-xs">{{ group.oldest_pending }}</code>
                        {% else %}
                            <span class="text-gray-400 dark:text-gray-500">&mdash;</span>
                        {% endif %}
                    </td>
                </tr>

                {% if group.consumer_list is not empty %}
                    <tr>
                        <td colspan="6" class="py-0 px-4 border-t border-gray-200 dark:border-gray-700">
                            <table class="mb-2 w-full text-left table-auto">
                                <thead>
                                <tr class="text-gray-600 dark:text-gray-300">
                                    <th class="py-1 pl-6 text-xs font-semibold uppercase">Consumer</th>
                                    <th class="py-1 px-4 w-24 text-xs font-semibold uppercase">Pending</th>
                                    <th class="py-1 px-4 w-32 text-xs font-semibold uppercase">Idle</th>
                                    <th class="py-1 px-4 w-32 text-xs font-semibold uppercase">Inactive</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for consumer in group.consumer_list %}
                                    <tr class="text-sm dark:text-gray-300">
                                        <td class="py-1 pl-6 break-all">{{ consumer.name }}</td>
                                        <td class="py-1 px-4 whitespace-nowrap">{{ consumer.pending|number }}</td>
                                        <td class="py-1 px-4 whitespace-nowrap">{{ (consumer.idle / 1000)|round }}s</td>
                                        <td class="py-1 px-4 whitespace-nowrap">
                                            {% if consumer.inactive is null %}
                                                <span class="text-gray-400 dark:text-gray-500" title="Redis 7.2+ only.">&mdash;</span>
                                            {% else %}
                                                {{ (consumer.inactive / 1000)|round }}s
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="py-1 pl-6 text-xs text-gray-500 border-t border-gray-200 dark:text-gray-400 dark:border-gray-700">
                            No consumers have read from this group yet.
                        </td>
                    </tr>
                {% endif %}
            {% endfor %}
            </tbody>
        </table>
    </div>

    <p class="py-2 px-4 text-xs text-gray-500 border-t border-gray-200 dark:text-gray-400 dark:border-gray-700">
        Pending entries were delivered to a consumer but never acknowledged (XACK).
        A consumer with pending entries and a high idle time has most likely died and left them stuck.
    </p>
</div>
